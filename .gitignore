# --- 📦 Dependencies ---
node_modules/
.pnp
.pnp.js

# --- 🏗️ Build Outputs ---
**/dist/
**/.next/
**/out/
**/build/
**/.turbo/
.docker/

# --- 🧪 Testing & Coverage ---
coverage/
*.lcov
.nyc_output

# --- 🔐 Environment & Secrets ---
.env
.env.*
!.env.example
*.pem
*.key

# --- 🖥️ OS & System ---
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# --- 🔧 IDEs & Tools ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- 🚀 CodeHost Specific ---
# Ignore temporary build folders created by the builder service
/tmp/
/uploads/
/builds/

# --- 🐘 Database (Prisma) ---
# We keep migrations but ignore local sqlite DBs or environment configs
*.db
*.db-journal
/packages/database/.env

# --- 📦 Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
docker-runtime-logs/
